{
    "manifest_version":  3,
    "name":  "GSecurity Ad Shield",
    "version":  "0.4.0",
    "description":  "Block ads and trackers across YouTube, Reddit, Facebook, Twitter/X, search engines, and 200+ ad networks.",
    "minimum_chrome_version":  "114",
    "permissions":  [
                        "declarativeNetRequest"
                    ],
    "host_permissions":  [
                             "\u003call_urls\u003e"
                         ],
    "declarative_net_request":  {
                                    "rule_resources":  [
                                                           {
                                                               "id":  "ruleset_1",
                                                               "enabled":  true,
                                                               "path":  "rules.json"
                                                           }
                                                       ]
                                },
    "background":  {
                       "service_worker":  "background.js"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "*://*.youtube.com/*",
                                                "*://*.youtube-nocookie.com/*"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_start",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "*://*.reddit.com/*",
                                                "*://*.facebook.com/*",
                                                "*://*.twitter.com/*",
                                                "*://*.x.com/*",
                                                "*://*.instagram.com/*",
                                                "*://*.linkedin.com/*",
                                                "*://*.twitch.tv/*",
                                                "*://*.tiktok.com/*",
                                                "*://*.cnn.com/*",
                                                "*://*.forbes.com/*",
                                                "*://*.nytimes.com/*",
                                                "*://*.washingtonpost.com/*",
                                                "*://*.theguardian.com/*",
                                                "*://*.bbc.com/*",
                                                "*://*.medium.com/*",
                                                "*://*.fandom.com/*",
                                                "*://*.wikia.com/*",
                                                "*://*.pinterest.com/*"
                                            ],
                                "js":  [
                                           "content-sites.js"
                                       ],
                                "run_at":  "document_start",
                                "all_frames":  true
                            },
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "exclude_matches":  [
                                                        "*://*.youtube.com/*",
                                                        "*://*.youtube-nocookie.com/*",
                                                        "*://*.reddit.com/*",
                                                        "*://*.facebook.com/*",
                                                        "*://*.twitter.com/*",
                                                        "*://*.x.com/*",
                                                        "*://*.instagram.com/*",
                                                        "*://*.linkedin.com/*",
                                                        "*://*.twitch.tv/*",
                                                        "*://*.tiktok.com/*"
                                                    ],
                                "js":  [
                                           "content-generic.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  true
                            }
                        ],
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "main-world.js"
                                                       ],
                                         "matches":  [
                                                         "\u003call_urls\u003e"
                                                     ]
                                     }
                                 ],
    "action":  {
                   "default_title":  "GSecurity Ad Shield",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "32":  "icons/icon32.png"
                                    }
               },
    "icons":  {
                  "16":  "icons/icon16.png",
                  "32":  "icons/icon32.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              }
}
